<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Weather service</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 760px;
            margin: 40px auto;
            padding: 0 20px;
            color: #222;
        }
        h1 {
            margin-bottom: 8px;
        }
        .muted {
            color: #666;
            margin-bottom: 24px;
        }
        form {
            display: flex;
            gap: 12px;
            margin-bottom: 24px;
        }
        input[type="text"] {
            flex: 1;
            padding: 12px;
            font-size: 16px;
        }
        button {
            padding: 12px 18px;
            font-size: 16px;
            cursor: pointer;
        }
        .card {
            border: 1px solid #ddd;
            border-radius: 10px;
            padding: 20px;
            background: #fafafa;
        }
        .error {
            color: #b00020;
            margin-bottom: 16px;
        }
        .result {
            font-size: 28px;
            font-weight: bold;
            margin-top: 8px;
        }
        code {
            background: #f1f1f1;
            padding: 2px 6px;
            border-radius: 4px;
        }
    </style>
</head>
<body>
<h1>Weather service</h1>
<p class="muted">
    Enter a city and the app will return the current temperature with a trend suffix based on the last 10 days average.
</p>

{% if error %}
    <div class="error">{{ error }}</div>
{% endif %}

<form method="post">
    <input type="text" name="city" value="{{ city }}" placeholder="e.g. Sofia">
    <button type="submit">Check weather</button>
</form>

{% if report %}
    <div class="card">
        <div><strong>City:</strong> {{ report.city }}</div>
        <div class="result">{{ report.formattedTemperature() }}</div>
        <div><strong>Fetched at:</strong> {{ report.fetchedAt.format('Y-m-d H:i:s') }}</div>
        <div style="margin-top: 12px;">
            API example:
            <code>/api/weather?city={{ report.city }}</code>
        </div>
    </div>
{% endif %}
</body>
</html>
